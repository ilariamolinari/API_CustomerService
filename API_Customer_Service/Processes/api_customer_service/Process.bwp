                                    tibex:xpdlId="ba869980-e49d-46df-ad27-5db8d92f27ed" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="Check_logToGroupEnd"/>
                                    <bpws:target linkName="LogToGroupEnd"/>
