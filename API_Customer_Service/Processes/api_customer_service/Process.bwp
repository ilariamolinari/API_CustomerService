                                    columnName="id"
                                    dataType="-5"
                                    status="OptionalElement" typeName="BIGINT"/>

                                    <columnMetadata
                                    columnIndex="2"
                                    columnName="name"
                                    dataType="12"
                                    status="OptionalElement" typeName="CHARACTER VARYING"/>

