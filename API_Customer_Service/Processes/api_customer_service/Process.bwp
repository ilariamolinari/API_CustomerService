                                    <bpws:targets>
                                    <bpws:target linkName="SelectToMapper"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="MapperToLog"/>
                                    </bpws:sources>
                                    <tibex:inputBindings>
                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns1=&quot;http://www.example.org/customers&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;Select&quot;/>&lt;xsl:template name=&quot;Mapper-input&quot; match=&quot;/&quot;>&lt;tns1:customers>&lt;xsl:for-each select=&quot;$Select/Record&quot;>&lt;tns1:customer>&lt;xsl:if test=&quot;name&quot;>&lt;tns1:name>&lt;xsl:value-of select=&quot;name&quot;/>&lt;/tns1:name>&lt;/xsl:if>&lt;xsl:if test=&quot;surname&quot;>&lt;tns1:surname>&lt;xsl:value-of select=&quot;surname&quot;/>&lt;/tns1:surname>&lt;/xsl:if>&lt;xsl:if test=&quot;phonenumber&quot;>&lt;tns1:phonenumber>&lt;xsl:value-of select=&quot;phonenumber&quot;/>&lt;/tns1:phonenumber>&lt;/xsl:if>&lt;xsl:if test=&quot;tiercode&quot;>&lt;tns1:tiercode>&lt;xsl:value-of select=&quot;tiercode&quot;/>&lt;/tns1:tiercode>&lt;/xsl:if>&lt;xsl:if test=&quot;createdate&quot;>&lt;tns1:createdate>&lt;xsl:value-of select=&quot;createdate&quot;/>&lt;/tns1:createdate>&lt;/xsl:if>&lt;/tns1:customer>&lt;/xsl:for-each>&lt;/tns1:customers>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>
                                    <bwext:BWActivity
                                    activityTypeID="bw.generalactivities.mapper"
                                    version="6.0.0.001"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:customers="http://www.example.org/customers"
                                    xmlns:generalactivities="http://ns.tibco.com/bw/palette/generalactivities" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>
                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">
                                    <type href="http://ns.tibco.com/bw/palette/generalactivities#//Mapper"/>
                                    <value
                                    inputQName="customers:customers" xsi:type="generalactivities:Mapper"/>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
                                </tibex:activityExtension>
                            </bpws:extensionActivity>
                            <bpws:extensionActivity>
                                <tibex:activityExtension
