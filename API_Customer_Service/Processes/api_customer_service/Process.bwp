                                    </bwext:BWActivity>
                                    </tibex:config>
                                    </tibex:activityExtension>
                                    </bpws:extensionActivity>
                                    <bpws:extensionActivity>

                                    <tibex:activityExtension
                                    inputVariable="Mapper3-input"
                                    name="Mapper3"
                                    outputVariable="Mapper3"
                                    tibex:xpdlId="7a3f7df5-593e-401b-bf18-e6fa3a7d2235" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="Debug_logToMapper3"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="Mapper3ToJDBCUpdate"/>
                                    </bpws:sources>
                                    <tibex:inputBindings>

                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns10=&quot;http://www.example.org/customers_id&quot; xmlns:xsd=&quot;http://www.w3.org/2001/XMLSchema&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;SingleCustomer&quot;/>&lt;xsl:template name=&quot;Mapper3-input&quot; match=&quot;/&quot;>&lt;tns10:customers_id>&lt;tns10:customer_id>&lt;xsl:if test=&quot;$SingleCustomer/tns10:id&quot;>&lt;tns10:id>&lt;xsl:value-of select=&quot;$SingleCustomer/tns10:id&quot;/>&lt;/tns10:id>&lt;/xsl:if>&lt;xsl:if test=&quot;if (exists($SingleCustomer/tns10:name)) then $SingleCustomer/tns10:name&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;>&lt;tns10:name>&lt;xsl:value-of select=&quot;if (exists($SingleCustomer/tns10:name)) then $SingleCustomer/tns10:name&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;/>&lt;/tns10:name>&lt;/xsl:if>&lt;xsl:if test=&quot;if (exists($SingleCustomer/tns10:surname)) then $SingleCustomer/tns10:surname&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;>&lt;tns10:surname>&lt;xsl:value-of select=&quot;if (exists($SingleCustomer/tns10:surname)) then $SingleCustomer/tns10:surname&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;/>&lt;/tns10:surname>&lt;/xsl:if>&lt;xsl:if test=&quot;if (exists($SingleCustomer/tns10:phonenumber)) then $SingleCustomer/tns10:phonenumber&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;>&lt;tns10:phonenumber>&lt;xsl:value-of select=&quot;if (exists($SingleCustomer/tns10:phonenumber)) then $SingleCustomer/tns10:phonenumber&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;/>&lt;/tns10:phonenumber>&lt;/xsl:if>&lt;xsl:if test=&quot;if (exists($SingleCustomer/tns10:tiercode)) then $SingleCustomer/tns10:tiercode&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;>&lt;tns10:tiercode>&lt;xsl:value-of select=&quot;if (exists($SingleCustomer/tns10:tiercode)) then $SingleCustomer/tns10:tiercode&amp;#xD;&amp;#xA;else &amp;quot; &amp;quot;&quot;/>&lt;/tns10:tiercode>&lt;/xsl:if>&lt;xsl:if test=&quot;$SingleCustomer/tns10:createdate&quot;>&lt;tns10:createdate>&lt;xsl:value-of select=&quot;$SingleCustomer/tns10:createdate&quot;/>&lt;/tns10:createdate>&lt;/xsl:if>&lt;/tns10:customer_id>&lt;/tns10:customers_id>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>

                                    <bwext:BWActivity
                                    activityTypeID="bw.generalactivities.mapper"
                                    version="6.0.0.001"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:customers_id="http://www.example.org/customers_id"
                                    xmlns:generalactivities="http://ns.tibco.com/bw/palette/generalactivities" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>

                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">

                                    <type href="http://ns.tibco.com/bw/palette/generalactivities#//Mapper"/>

                                    <value
                                    inputQName="customers_id:customers_id" xsi:type="generalactivities:Mapper"/>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
                                    </tibex:activityExtension>
                                    </bpws:extensionActivity>
                                    <bpws:extensionActivity>

                                    <tibex:activityExtension
                                    inputVariable="Partial_Update-input"
                                    name="Partial_Update"
                                    outputVariable="Partial_Update"
                                    tibex:xpdlId="282b31a6-64b8-48d9-8547-f5d5008651a4" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="Mapper3ToJDBCUpdate"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="Partial_UpdateToGroupEnd1"/>
                                    </bpws:sources>
                                    <tibex:inputBindings>

                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns14=&quot;http://www.tibco.com/namespaces/tnt/plugins/jdbc+282b31a6-64b8-48d9-8547-f5d5008651a4+input&quot; xmlns:tns10=&quot;http://www.example.org/customers_id&quot; xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot; xmlns:xsd=&quot;http://www.w3.org/2001/XMLSchema&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;Mapper3&quot;/>&lt;xsl:template name=&quot;Partial_Update-input&quot; match=&quot;/&quot;>&lt;tns14:jdbcUpdateActivityInput>&lt;name>&lt;xsl:choose>&lt;xsl:when test=&quot;exists($Mapper3/tns10:customer_id[1]/tns10:name)&quot;>&lt;xsl:value-of select=&quot;$Mapper3/tns10:customer_id[1]/tns10:name&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/name>&lt;surname>&lt;xsl:choose>&lt;xsl:when test=&quot;exists($Mapper3/tns10:customer_id[1]/tns10:surname)&quot;>&lt;xsl:value-of select=&quot;$Mapper3/tns10:customer_id[1]/tns10:surname&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/surname>&lt;phonenumber>&lt;xsl:choose>&lt;xsl:when test=&quot;exists($Mapper3/tns10:customer_id[1]/tns10:phonenumber)&quot;>&lt;xsl:value-of select=&quot;$Mapper3/tns10:customer_id[1]/tns10:phonenumber&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/phonenumber>&lt;tiercode>&lt;xsl:choose>&lt;xsl:when test=&quot;exists($Mapper3/tns10:customer_id[1]/tns10:tiercode)&quot;>&lt;xsl:value-of select=&quot;$Mapper3/tns10:customer_id[1]/tns10:tiercode&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/tiercode>&lt;id>&lt;xsl:value-of select=&quot;xsd:int($Mapper3/tns10:customer_id[1]/tns10:id)&quot;/>&lt;/id>&lt;/tns14:jdbcUpdateActivityInput>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>

                                    <bwext:BWActivity
                                    activityTypeID="bw.jdbc.update"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:jdbcPalette="http://ns.tibco.com/bw/palette/jdbc" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>

                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">

                                    <type href="http://ns.tibco.com/bw/palette/jdbc#//JDBCUpdateActivity"/>

                                    <value
                                    sharedResourceProperty="jdbcProperty"
                                    sqlStatement="UPDATE customer&#xd;&#xa;SET &#xd;&#xa;&#x9;name = COALESCE(NULLIF(?, ' '), name),&#xd;&#xa;&#x9;surname = COALESCE(NULLIF(?, ' '), surname),&#xd;&#xa;&#x9;phonenumber = COALESCE(NULLIF(?, ' '), phonenumber),&#xd;&#xa;&#x9;tiercode = COALESCE(CAST(NULLIF(?, ' ') AS INTEGER), tiercode)&#xd;&#xa;WHERE customerid = ?"
                                    timeout="10" xsi:type="jdbcPalette:JDBCUpdateActivity">

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="name"/>

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="surname"/>

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="phonenumber"/>

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="tiercode"/>

                                    <PreparedParameters
                                    DataType="4"
                                    DataTypeDisplayValue="INTEGER" ParameterName="id"/>
                                    </value>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
                                    </tibex:activityExtension>
