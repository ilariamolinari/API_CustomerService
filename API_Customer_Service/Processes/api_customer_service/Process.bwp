                                    </bpws:extensionActivity>
                                    <bpws:extensionActivity>

                                    <tibex:activityExtension
                                    inputVariable="Insert-input"
                                    name="Insert"
                                    outputVariable="Insert"
                                    tibex:xpdlId="c4e35070-d3d7-4691-be50-281100a0683c" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="GroupStartToJDBCUpdate"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="InsertToJDBCQuery">
                                    <tibex:DesignExpression>

                                    <tibex:expression
                                    expression="$Insert/noOfUpdates = 1" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath2.0"/>
                                    </tibex:DesignExpression>

                                    <bpws:transitionCondition expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath2.0"><![CDATA[$Insert/noOfUpdates = 1]]></bpws:transitionCondition>
                                    </bpws:source>
                                    <bpws:source linkName="InsertToCheck_error">
                                    <tibex:DesignExpression>

                                    <tibex:expression
                                    expression="$Insert/noOfUpdates = 0" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath2.0"/>
                                    </tibex:DesignExpression>

                                    <bpws:transitionCondition expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath2.0"><![CDATA[$Insert/noOfUpdates = 0]]></bpws:transitionCondition>
                                    </bpws:source>
                                    </bpws:sources>
                                    <tibex:inputBindings>

                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns3=&quot;http://www.tibco.com/namespaces/tnt/plugins/jdbc+c4e35070-d3d7-4691-be50-281100a0683c+input&quot; xmlns:tns1=&quot;http://www.example.org/customers&quot; xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot; xmlns:xsd=&quot;http://www.w3.org/2001/XMLSchema&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;SingleCustomer&quot;/>&lt;xsl:template name=&quot;Insert-input&quot; match=&quot;/&quot;>&lt;xsl:for-each select=&quot;$SingleCustomer&quot;>&lt;tns3:jdbcUpdateActivityInput>&lt;name>&lt;xsl:choose>&lt;xsl:when test=&quot;exists(tns1:name)&quot;>&lt;xsl:value-of select=&quot;tns1:name&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/name>&lt;surname>&lt;xsl:choose>&lt;xsl:when test=&quot;exists(tns1:surname)&quot;>&lt;xsl:value-of select=&quot;tns1:surname&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/surname>&lt;phonenumber>&lt;xsl:choose>&lt;xsl:when test=&quot;exists(tns1:phonenumber)&quot;>&lt;xsl:value-of select=&quot;tns1:phonenumber&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/phonenumber>&lt;tiercode>&lt;xsl:value-of select=&quot;xsd:int(tns1:tiercode)&quot;/>&lt;/tiercode>&lt;createdate>&lt;xsl:choose>&lt;xsl:when test=&quot;exists(tns1:createdate)&quot;>&lt;xsl:value-of select=&quot;tns1:createdate&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/createdate>&lt;/tns3:jdbcUpdateActivityInput>&lt;/xsl:for-each>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>

                                    <bwext:BWActivity
                                    activityTypeID="bw.jdbc.update"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:jdbcPalette="http://ns.tibco.com/bw/palette/jdbc" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>

                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">

                                    <type href="http://ns.tibco.com/bw/palette/jdbc#//JDBCUpdateActivity"/>

                                    <value
                                    sharedResourceProperty="jdbcProperty"
                                    sqlStatement="INSERT INTO customer (name, surname, phonenumber, &#xd;&#xa;tiercode, createdate)&#xd;&#xa;VALUES (?,?,?,?,?)&#xd;&#xa;ON CONFLICT (phonenumber) DO NOTHING;"
                                    timeout="10" xsi:type="jdbcPalette:JDBCUpdateActivity">

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="name"/>

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="surname"/>

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="phonenumber"/>

                                    <PreparedParameters
                                    DataType="4"
                                    DataTypeDisplayValue="INTEGER" ParameterName="tiercode"/>

                                    <PreparedParameters
                                    DataType="91"
                                    DataTypeDisplayValue="DATE" ParameterName="createdate"/>
                                    </value>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
                                    </tibex:activityExtension>
                                    </bpws:extensionActivity>
                                    <bpws:extensionActivity>

                                    <tibex:activityExtension
                                    inputVariable="Insert_check-input"
                                    name="Insert_check"
                                    outputVariable="Insert_check"
                                    tibex:xpdlId="f3df083d-8a03-4d90-9e77-a2923a41bd3a" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="InsertToJDBCQuery"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="Insert_checkToCheck_log"/>
                                    </bpws:sources>
                                    <tibex:inputBindings>

                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns4=&quot;http://www.tibco.com/namespaces/tnt/plugins/jdbc+f3df083d-8a03-4d90-9e77-a2923a41bd3a+input&quot; xmlns:tns1=&quot;http://www.example.org/customers&quot; xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;SingleCustomer&quot;/>&lt;xsl:template name=&quot;Insert_check-input&quot; match=&quot;/&quot;>&lt;tns4:jdbcQueryActivityInput>&lt;phonenumber>&lt;xsl:choose>&lt;xsl:when test=&quot;exists($SingleCustomer/tns1:phonenumber)&quot;>&lt;xsl:value-of select=&quot;$SingleCustomer/tns1:phonenumber&quot;/>&lt;/xsl:when>&lt;xsl:otherwise>&lt;xsl:attribute name=&quot;xsi:nil&quot;>true&lt;/xsl:attribute>&lt;/xsl:otherwise>&lt;/xsl:choose>&lt;/phonenumber>&lt;/tns4:jdbcQueryActivityInput>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>

                                    <bwext:BWActivity
                                    activityTypeID="bw.jdbc.JDBCQuery"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:jdbcPalette="http://ns.tibco.com/bw/palette/jdbc" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>

                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">

                                    <type href="http://ns.tibco.com/bw/palette/jdbc#//JDBCQueryActivity"/>

                                    <value
                                    maxRows="100"
                                    sharedResourceProperty="jdbcProperty"
                                    sqlStatement="SELECT customerid AS id, &#xa;name, surname, phonenumber, tiercode, createdate&#xa;FROM customer WHERE phonenumber = ?;&#xa;"
                                    timeout="10" xsi:type="jdbcPalette:JDBCQueryActivity">

                                    <PreparedParameters
                                    DataType="12"
                                    DataTypeDisplayValue="VARCHAR" ParameterName="phonenumber"/>

                                    <columnMetadata
                                    columnIndex="1"
                                    columnName="id"
                                    dataType="-5"
                                    status="OptionalElement" typeName="BIGINT"/>

                                    <columnMetadata
                                    columnIndex="2"
                                    columnName="name"
                                    dataType="12"
                                    status="OptionalElement" typeName="CHARACTER VARYING"/>

                                    <columnMetadata
                                    columnIndex="3"
                                    columnName="surname"
                                    dataType="12"
                                    status="OptionalElement" typeName="CHARACTER VARYING"/>

                                    <columnMetadata
                                    columnIndex="4"
                                    columnName="phonenumber"
                                    dataType="12"
                                    status="OptionalElement" typeName="CHARACTER VARYING"/>

                                    <columnMetadata
                                    columnIndex="5"
                                    columnName="tiercode"
                                    dataType="4"
                                    status="OptionalElement" typeName="INTEGER"/>

                                    <columnMetadata
                                    columnIndex="6"
                                    columnName="createdate"
                                    dataType="91"
                                    status="OptionalElement" typeName="DATE"/>
                                    </value>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
                                    </tibex:activityExtension>
                                    </bpws:extensionActivity>
                                    <bpws:extensionActivity>

                                    <tibex:activityExtension
                                    inputVariable="Check_log-input"
                                    name="Check_log"
                                    tibex:xpdlId="57e2c817-35f0-494c-9aed-7d4d2a2369ff" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="Insert_checkToCheck_log"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="Check_logToGroupEnd"/>
                                    </bpws:sources>
                                    <tibex:inputBindings>

                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns=&quot;http://www.tibco.com/pe/WriteToLogActivitySchema&quot; xmlns:xsd=&quot;http://www.w3.org/2001/XMLSchema&quot; xmlns:tns1=&quot;http://www.example.org/customers&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;SingleCustomer&quot;/>&lt;xsl:param name=&quot;Insert_check&quot;/>&lt;xsl:template name=&quot;Check_log-input&quot; match=&quot;/&quot;>&lt;tns:ActivityInput>&lt;message>&lt;xsl:value-of select=&quot;concat(&amp;quot;Customer &amp;quot;, $SingleCustomer/tns1:name, &amp;quot; &amp;quot;, $SingleCustomer/tns1:surname, &amp;quot; added to customers list with ID: &amp;quot;, xsd:string($Insert_check/Record[1]/id))&quot;/>&lt;/message>&lt;/tns:ActivityInput>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>

                                    <bwext:BWActivity
                                    activityTypeID="bw.generalactivities.log"
                                    version="6.0.0.001"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:generalactivities="http://ns.tibco.com/bw/palette/generalactivities" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>

                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">

                                    <type href="http://ns.tibco.com/bw/palette/generalactivities#//Log"/>

                                    <value
                                    controlBy="Application"
                                    role="Info"
                                    suppressJobInfo="true" xsi:type="generalactivities:Log"/>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
                                    </tibex:activityExtension>
                                    </bpws:extensionActivity>
                                    <bpws:extensionActivity>

                                    <tibex:activityExtension
                                    inputVariable="Check_error-input"
                                    name="Check_error"
                                    tibex:xpdlId="3e98ef6c-44d0-4619-a08e-7bc539c69f16" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="InsertToCheck_error"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="LogToGroupEnd"/>
                                    </bpws:sources>
                                    <tibex:inputBindings>

                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns=&quot;http://www.tibco.com/pe/WriteToLogActivitySchema&quot; xmlns:tns1=&quot;http://www.example.org/customers&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;SingleCustomer&quot;/>&lt;xsl:template name=&quot;Log-input&quot; match=&quot;/&quot;>&lt;tns:ActivityInput>&lt;message>&lt;xsl:value-of select=&quot;concat(&amp;quot;ERROR: could not insert &amp;quot;, $SingleCustomer/tns1:name, &amp;quot; &amp;quot;, $SingleCustomer/tns1:surname, &amp;quot; into customers list.&amp;quot;)&quot;/>&lt;/message>&lt;/tns:ActivityInput>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>

                                    <bwext:BWActivity
                                    activityTypeID="bw.generalactivities.log"
                                    version="6.0.0.001"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:generalactivities="http://ns.tibco.com/bw/palette/generalactivities" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>

                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">

                                    <type href="http://ns.tibco.com/bw/palette/generalactivities#//Log"/>

                                    <value
                                    controlBy="Application"
                                    role="Error"
                                    suppressJobInfo="true" xsi:type="generalactivities:Log"/>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
                                    </tibex:activityExtension>
