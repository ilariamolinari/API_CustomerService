                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns2=&quot;http://xmlns.example.com/20260319160400PLT&quot; xmlns:tns10=&quot;http://www.example.org/customers_id&quot; version=&quot;2.0&quot;>&#xa;    &lt;xsl:param name=&quot;patch.item&quot;/>&#xa;    &lt;xsl:template name=&quot;patchOut-input&quot; match=&quot;/&quot;>&#xa;        &lt;tns10:customers_id>&#xa;            &lt;xsl:for-each select=&quot;$patch.item/tns10:customer_id&quot;>&#xa;                &lt;tns10:customer_id>&#xa;                    &lt;xsl:if test=&quot;tns10:id&quot;>&#xa;                        &lt;tns10:id>&#xa;                            &lt;xsl:value-of select=&quot;tns10:id&quot;/>&#xa;                        &lt;/tns10:id>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns10:name&quot;>&#xa;                        &lt;tns10:name>&#xa;                            &lt;xsl:value-of select=&quot;tns10:name&quot;/>&#xa;                        &lt;/tns10:name>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns10:surname&quot;>&#xa;                        &lt;tns10:surname>&#xa;                            &lt;xsl:value-of select=&quot;tns10:surname&quot;/>&#xa;                        &lt;/tns10:surname>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns10:phonenumber&quot;>&#xa;                        &lt;tns10:phonenumber>&#xa;                            &lt;xsl:value-of select=&quot;tns10:phonenumber&quot;/>&#xa;                        &lt;/tns10:phonenumber>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns10:tiercode&quot;>&#xa;                        &lt;tns10:tiercode>&#xa;                            &lt;xsl:value-of select=&quot;tns10:tiercode&quot;/>&#xa;                        &lt;/tns10:tiercode>