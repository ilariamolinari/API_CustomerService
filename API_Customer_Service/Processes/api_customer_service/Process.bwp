                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns2=&quot;http://xmlns.example.com/20260319160400PLT&quot; xmlns:tns1=&quot;http://www.example.org/customers&quot; version=&quot;2.0&quot;>&#xa;    &lt;xsl:param name=&quot;Mapper&quot;/>&#xa;    &lt;xsl:template name=&quot;getOut-input&quot; match=&quot;/&quot;>&#xa;        &lt;tns1:customers>&#xa;            &lt;xsl:for-each select=&quot;$Mapper/tns1:customer&quot;>&#xa;                &lt;tns1:customer>&#xa;                    &lt;xsl:if test=&quot;tns1:name&quot;>&#xa;                        &lt;tns1:name>&#xa;                            &lt;xsl:value-of select=&quot;tns1:name&quot;/>&#xa;                        &lt;/tns1:name>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns1:surname&quot;>&#xa;                        &lt;tns1:surname>&#xa;                            &lt;xsl:value-of select=&quot;tns1:surname&quot;/>&#xa;                        &lt;/tns1:surname>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns1:phonenumber&quot;>&#xa;                        &lt;tns1:phonenumber>&#xa;                            &lt;xsl:value-of select=&quot;tns1:phonenumber&quot;/>&#xa;                        &lt;/tns1:phonenumber>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns1:tiercode&quot;>&#xa;                        &lt;tns1:tiercode>&#xa;                            &lt;xsl:value-of select=&quot;tns1:tiercode&quot;/>&#xa;                        &lt;/tns1:tiercode>&#xa;                    &lt;/xsl:if>&#xa;                    &lt;xsl:if test=&quot;tns1:createdate&quot;>&#xa;                        &lt;tns1:createdate>&#xa;                            &lt;xsl:value-of select=&quot;tns1:createdate&quot;/>&#xa;                        &lt;/tns1:createdate>&#xa;                    &lt;/xsl:if>&#xa;                &lt;/tns1:customer>&#xa;            &lt;/xsl:for-each>&#xa;        &lt;/tns1:customers>&#xa;    &lt;/xsl:template>&#xa;&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                </tibex:inputBindings>
                                <tibex:inputBinding expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0">&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:tns2="http://xmlns.example.com/20260319160400PLT" xmlns:tns1="http://www.example.org/customers" version="2.0"&gt;&lt;xsl:param name="Mapper"/&gt;&lt;xsl:template name="getOut-input" match="/"&gt;&lt;tns2:getResponse&gt;&lt;item&gt;&lt;tns1:customers&gt;&lt;xsl:for-each select="$Mapper/tns1:customer"&gt;&lt;tns1:customer&gt;&lt;xsl:if test="tns1:name"&gt;&lt;tns1:name&gt;&lt;xsl:value-of select="tns1:name"/&gt;&lt;/tns1:name&gt;&lt;/xsl:if&gt;&lt;xsl:if test="tns1:surname"&gt;&lt;tns1:surname&gt;&lt;xsl:value-of select="tns1:surname"/&gt;&lt;/tns1:surname&gt;&lt;/xsl:if&gt;&lt;xsl:if test="tns1:phonenumber"&gt;&lt;tns1:phonenumber&gt;&lt;xsl:value-of select="tns1:phonenumber"/&gt;&lt;/tns1:phonenumber&gt;&lt;/xsl:if&gt;&lt;xsl:if test="tns1:tiercode"&gt;&lt;tns1:tiercode&gt;&lt;xsl:value-of select="tns1:tiercode"/&gt;&lt;/tns1:tiercode&gt;&lt;/xsl:if&gt;&lt;xsl:if test="tns1:createdate"&gt;&lt;tns1:createdate&gt;&lt;xsl:value-of select="tns1:createdate"/&gt;&lt;/tns1:createdate&gt;&lt;/xsl:if&gt;&lt;/tns1:customer&gt;&lt;/xsl:for-each&gt;&lt;/tns1:customers&gt;&lt;/item&gt;&lt;/tns2:getResponse&gt;&lt;/xsl:template&gt;&lt;/xsl:stylesheet&gt;</tibex:inputBinding>
                                <bpws:targets>
                                    <bpws:target linkName="Get_endTogetOut"/>
                                </bpws:targets>
                                <bpws:sources>
                                    <bpws:source linkName="getOutToOnMessageEnd"/>
                                </bpws:sources>
                            </bpws:reply>
                            <bpws:extensionActivity>
                                <tibex:activityExtension
                                    inputVariable="Get_start-input"
                                    name="Get_start"
                                    tibex:xpdlId="cd57a6e7-e7c7-459f-804f-3d7abe9ab36f" xmlns:tibex="http://www.tibco.com/bpel/2007/extensions">
                                    <bpws:targets>
                                    <bpws:target linkName="OnMessageStartToLog"/>
                                    </bpws:targets>
                                    <bpws:sources>
                                    <bpws:source linkName="Get_startToJDBCQuery"/>
                                    </bpws:sources>
                                    <tibex:inputBindings>
                                    <tibex:inputBinding
                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns=&quot;http://www.tibco.com/pe/WriteToLogActivitySchema&quot; version=&quot;2.0&quot;>&lt;xsl:template name=&quot;Get_start-input&quot; match=&quot;/&quot;>&lt;tns:ActivityInput>&lt;message>&lt;xsl:value-of select=&quot;&amp;quot;GETting started...&amp;quot;&quot;/>&lt;/message>&lt;/tns:ActivityInput>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
                                    <tibex:config>
                                    <bwext:BWActivity
                                    activityTypeID="bw.generalactivities.log"
                                    version="6.0.0.001"
                                    xmlns:activityconfig="http://tns.tibco.com/bw/model/activityconfig"
                                    xmlns:bwext="http://tns.tibco.com/bw/model/core/bwext"
                                    xmlns:generalactivities="http://ns.tibco.com/bw/palette/generalactivities" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                                    <activityConfig>
                                    <properties
                                    name="config" xsi:type="activityconfig:EMFProperty">
                                    <type href="http://ns.tibco.com/bw/palette/generalactivities#//Log"/>
                                    <value
