                                    expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns10=&quot;http://www.example.org/customers_id&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;Insert_check&quot;/>&lt;xsl:template name=&quot;Mapper4-input&quot; match=&quot;/&quot;>&lt;tns10:customers_id>&lt;xsl:for-each select=&quot;$Insert_check/Record&quot;>&lt;tns10:customer_id>&lt;xsl:if test=&quot;id&quot;>&lt;tns10:id>&lt;xsl:value-of select=&quot;id&quot;/>&lt;/tns10:id>&lt;/xsl:if>&lt;xsl:if test=&quot;name&quot;>&lt;tns10:name>&lt;xsl:value-of select=&quot;name&quot;/>&lt;/tns10:name>&lt;/xsl:if>&lt;xsl:if test=&quot;surname&quot;>&lt;tns10:surname>&lt;xsl:value-of select=&quot;surname&quot;/>&lt;/tns10:surname>&lt;/xsl:if>&lt;xsl:if test=&quot;phonenumber&quot;>&lt;tns10:phonenumber>&lt;xsl:value-of select=&quot;phonenumber&quot;/>&lt;/tns10:phonenumber>&lt;/xsl:if>&lt;xsl:if test=&quot;tiercode&quot;>&lt;tns10:tiercode>&lt;xsl:value-of select=&quot;tiercode&quot;/>&lt;/tns10:tiercode>&lt;/xsl:if>&lt;xsl:if test=&quot;createdate&quot;>&lt;tns10:createdate>&lt;xsl:value-of select=&quot;createdate&quot;/>&lt;/tns10:createdate>&lt;/xsl:if>&lt;/tns10:customer_id>&lt;/xsl:for-each>&lt;/tns10:customers_id>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                                    </tibex:inputBindings>
