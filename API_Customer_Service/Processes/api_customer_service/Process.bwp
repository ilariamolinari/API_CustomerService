                                    <bpws:finalCounterValue expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath2.0"><![CDATA[count($post.item/ns5:customer)]]></bpws:finalCounterValue>
                                    <bpws:scope name="innerScope">
