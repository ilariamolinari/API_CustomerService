                                    columnName="cnt"
                                    dataType="-5"
                                    status="OptionalElement" typeName="BIGINT"/>
                                    </value>
                                    </properties>
                                    </activityConfig>
                                    </bwext:BWActivity>
                                    </tibex:config>
