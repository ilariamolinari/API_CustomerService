    <tibex:VariableDescriptor type="MemorySaving">
        <task name="Iterate">
            <endingVariables>
                <variable>Start</variable>
                <variable>SingleCustomer</variable>
            </endingVariables>
        </task>
        <task name="GroupEnd">
            <endingVariables>
                <variable>Query</variable>
            </endingVariables>
        </task>
        <task name="Query">
            <endingVariables>
                <variable>Query-input</variable>
            </endingVariables>
        </task>
        <task name="Update_log">
            <endingVariables>
                <variable>Update_log-input</variable>
            </endingVariables>
        </task>
        <task name="Update">
            <endingVariables>
                <variable>Update-input</variable>
                <variable>Update</variable>
            </endingVariables>
        </task>
        <task name="Error_log">
            <endingVariables>
                <variable>Error_log-input</variable>
            </endingVariables>
        </task>
        <task name="Catch_All_log">
            <endingVariables>
                <variable>Catch_All_log-input</variable>
            </endingVariables>
        </task>
    </tibex:VariableDescriptor>
