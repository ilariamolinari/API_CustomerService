                                    <bpws:sources>
                                    <bpws:source linkName="GroupStartToJDBCQuery"/>
                                    </bpws:sources>
                                    <bpws:copy>
                                    <bpws:from expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath2.0"><![CDATA[($Start/ns0:customer_id)[number($index)]]]></bpws:from>
                                    <bpws:to variable="SingleCustomer"/>
                                    </bpws:copy>
                                </bpws:assign>
                                <bpws:empty name="GroupEnd"
